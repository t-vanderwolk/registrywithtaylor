generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id               String              @id @default(cuid())
  title            String
  slug             String              @unique
  content          String
  excerpt          String?
  /// Deprecated: use `status` instead.
  published        Boolean             @default(false)
  authorId         String
  views            Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  coverImage       String?
  category         String              @default("Registry Strategy")
  featuredImageId  String?
  archivedAt       DateTime?
  deck             String?
  featured         Boolean             @default(false)
  publishedAt      DateTime?
  scheduledFor     DateTime?
  status           PostStatus          @default(DRAFT)
  stage            BlogStage           @default(DRAFT)
  focusKeyword     String?
  seoTitle         String?
  seoDescription   String?
  canonicalUrl     String?
  featuredImageUrl String?             @map("featuredImage")
  affiliateLinks   AffiliateLink[]
  affiliates       BlogPostAffiliate[]
  affiliateBrands  Brand[]             @relation("PostAffiliateBrands")
  author           User                @relation(fields: [authorId], references: [id])
  featuredImage    Media?              @relation("FeaturedPostMedia", fields: [featuredImageId], references: [id])
  analytics        PostAnalytics[]
  images           PostImage[]
  media            Media[]             @relation("PostMedia")
}

model PostImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String?
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Media {
  id              String   @id @default(cuid())
  url             String
  fileName        String
  fileType        String
  fileSize        Int
  createdAt       DateTime @default(now())
  featuredInPosts Post[]   @relation("FeaturedPostMedia")
  posts           Post[]   @relation("PostMedia")
}

model PrintableResource {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  category    String?
  filePath    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PostAnalytics {
  id        String   @id @default(cuid())
  postId    String
  event     String
  meta      Json?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Brand {
  id             String             @id @default(cuid())
  name           String             @unique
  website        String?
  logoUrl        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  programs       AffiliateProgram[]
  legacyPartners AffiliatePartner[]
  posts          Post[]             @relation("PostAffiliateBrands")
}

model AffiliateProgram {
  id             String             @id @default(cuid())
  brandId        String
  network        AffiliateNetwork
  campaignId     String?            @unique
  commission     String?
  cookieLength   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  brand          Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  legacyPartners AffiliatePartner[]
  links          AffiliateLink[]

  @@unique([brandId, network])
  @@index([brandId])
}

model AffiliatePartner {
  id             String              @id @default(uuid())
  name           String
  brandId        String?
  programId      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  network        AffiliateNetwork
  advertiserId   String?
  commissionType CommissionType
  commissionRate String
  category       String?
  threeMonthEpc  Float?
  sevenDayEpc    Float?
  notes          String?
  isActive       Boolean             @default(true)
  allowedDomains String[]            @default([])
  slug           String              @unique
  logoUrl        String?
  website        String?
  affiliateLink  String?
  brand          Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  program        AffiliateProgram?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  affiliateLinks AffiliateLink[]
  blogPosts      BlogPostAffiliate[]

  @@unique([name, network])
  @@index([brandId])
  @@index([programId])
}

model BlogPostAffiliate {
  id          String           @id @default(cuid())
  blogPostId  String
  affiliateId String
  createdAt   DateTime         @default(now())
  affiliate   AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  blogPost    Post             @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, affiliateId])
}

model AffiliateLink {
  id             String            @id @default(uuid())
  programId      String?
  partnerId      String?
  name           String?
  url            String?
  destinationUrl String?
  code           String?           @unique
  label          String?
  blogPostId     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  clicks         AffiliateClick[]
  blogPost       Post?             @relation(fields: [blogPostId], references: [id])
  program        AffiliateProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  partner        AffiliatePartner? @relation(fields: [partnerId], references: [id])

  @@index([programId])
  @@index([partnerId])
  @@index([createdAt])
  @@index([blogPostId])
}

model AffiliateClick {
  id        String        @id @default(uuid())
  linkId    String
  ipHash    String?
  userAgent String?
  referrer  String?
  createdAt DateTime      @default(now())
  path      String?
  link      AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([createdAt])
}

model BookingEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  type        String
  sourcePage  String?
  service     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  userAgent   String?
  ipHash      String?

  @@index([createdAt])
  @@index([type, createdAt])
}

model ConsultationRequest {
  id         Int                   @id @default(autoincrement())
  name       String
  email      String
  dueDate    DateTime?             @db.Timestamp(6)
  city       String?
  babyNumber String?
  message    String?
  status     String?               @default("new")
  createdAt  DateTime?             @default(now()) @db.Timestamp(6)
  response   ConsultationResponse?
}

model ConsultationResponse {
  id             Int                 @id @default(autoincrement())
  consultationId Int                 @unique
  adminMessage   String
  meetingLink    String?
  scheduledTime  DateTime?           @db.Timestamp(6)
  createdAt      DateTime?           @default(now()) @db.Timestamp(6)
  consultation   ConsultationRequest @relation(fields: [consultationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ContactInquiry {
  id             Int       @id @default(autoincrement())
  fullName       String
  email          String
  service        String?
  dueDate        DateTime? @db.Timestamp(6)
  registryLink   String?
  homeType       String?
  budgetRange    String?
  topConcerns    String?
  biggestStress  String?
  location       String?
  levelOfSupport String?
  timeline       String?
  notes          String?
  referrer       String?
  sourceUrl      String?
  status         String?   @default("new")
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
}

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum BlogStage {
  IDEA
  OUTLINE
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum AffiliateNetwork {
  CJ
  IMPACT
  AWIN
  DIRECT
}

enum CommissionType {
  PERCENTAGE
  CPL
  FLAT_FEE
  VARIABLE
}
