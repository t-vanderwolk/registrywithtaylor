generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  role           Role         @default(USER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  name           String?
  slug           String?      @unique
  bio            String?
  expertiseAreas String[]     @default([])
  avatarUrl      String?
  guides         Guide[]        @relation("PrimaryGuideAuthor")
  posts          Post[]         @relation("PrimaryPostAuthor")
  authoredPosts  PostAuthor[]
  moduleNotes    ModuleNote[]
  registries     Registry[]
}

model Post {
  id               String              @id @default(cuid())
  title            String
  slug             String              @unique
  content          String
  excerpt          String?
  /// Deprecated: use `status` instead.
  published        Boolean             @default(false)
  authorId         String
  views            Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  coverImage       String?
  category         String              @default("Registry Strategy")
  featuredImageId  String?
  archivedAt       DateTime?
  deck             String?
  featured         Boolean             @default(false)
  publishedAt      DateTime?
  scheduledFor     DateTime?
  status           PostStatus          @default(DRAFT)
  stage            BlogStage           @default(DRAFT)
  focusKeyword     String?
  seoTitle         String?
  seoDescription   String?
  canonicalUrl     String?
  featuredImageUrl String?             @map("featuredImage")
  readingTime      Int?
  shareTitle       String?
  shareDescription String?
  affiliateClicks  AffiliateClick[]
  affiliateLinks   AffiliateLink[]
  affiliates       BlogPostAffiliate[]
  author           User                @relation("PrimaryPostAuthor", fields: [authorId], references: [id])
  featuredImage    Media?              @relation("FeaturedPostMedia", fields: [featuredImageId], references: [id])
  analytics        PostAnalytics[]
  authorships      PostAuthor[]
  comments         PostComment[]
  images           PostImage[]
  affiliateBrands  Brand[]             @relation("PostAffiliateBrands")
  media            Media[]             @relation("PostMedia")
}

model PostComment {
  id          String   @id @default(cuid())
  postId      String
  authorName  String
  authorEmail String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorEmail])
}

model PostAuthor {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  role      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String?
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Media {
  id              String   @id @default(cuid())
  url             String
  fileName        String
  fileType        String
  fileSize        Int
  createdAt       DateTime @default(now())
  featuredInPosts Post[]   @relation("FeaturedPostMedia")
  posts           Post[]   @relation("PostMedia")
}

model PrintableResource {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  category    String?
  filePath    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PostAnalytics {
  id        String   @id @default(cuid())
  postId    String
  event     String
  meta      Json?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], map: "idx_postanalytics_postid")
}

// Durable, cookie-independent per-visitor view de-duplication. One row per
// (scope, content, visitorHash, day-bucket). A unique-constraint violation on
// insert means the visitor was already counted for that content that day, so
// the view counter only increments on a successful insert. Survives cookie
// clearing (keyed on a hash of IP + user-agent).
model ViewDedup {
  id          String   @id @default(cuid())
  scope       String
  contentId   String
  visitorHash String
  bucket      Int
  createdAt   DateTime @default(now())

  @@unique([scope, contentId, visitorHash, bucket], map: "uniq_viewdedup_scope_content_visitor_bucket")
  @@index([createdAt], map: "idx_viewdedup_createdat")
}

// Unified outbound affiliate-click log across every surface (tools, blog, and
// any tracked anchor). This is the site's own count of real, bot-filtered
// clicks, so the admin dashboard can show a by-retailer breakdown to reconcile
// against each affiliate network's dashboard (Impact, CJ, MacroBaby, etc.).
model OutboundClick {
  id          String   @id @default(cuid())
  retailer    String
  network     String?
  brand       String?
  product     String?
  url         String
  source      String?
  pageType    String?
  path        String?
  visitorHash String?
  createdAt   DateTime @default(now())

  @@index([retailer, createdAt], map: "idx_outboundclick_retailer_createdat")
  @@index([createdAt], map: "idx_outboundclick_createdat")
}

model Guide {
  id                           String           @id @default(cuid())
  title                        String
  slug                         String           @unique
  excerpt                      String?
  intro                        String?
  content                      String
  conclusion                   String?
  heroImageUrl                 String?
  heroImageAlt                 String?
  authorId                     String
  category                     String           @default("Strollers")
  topicCluster                 String?
  status                       PostStatus       @default(DRAFT)
  publishedAt                  DateTime?
  scheduledFor                 DateTime?
  archivedAt                   DateTime?
  seoTitle                     String?
  seoDescription               String?
  ogTitle                      String?
  ogDescription                String?
  ogImageUrl                   String?
  ogImageAlt                   String?
  canonicalUrl                 String?
  targetKeyword                String?
  secondaryKeywords            String[]         @default([])
  internalLinkNotes            String?
  tableOfContentsEnabled       Boolean          @default(true)
  faqItems                     Json             @default("[]")
  affiliateDisclosureEnabled   Boolean          @default(true)
  affiliateDisclosureText      String?
  affiliateDisclosurePlacement String?          @default("before_affiliates")
  affiliateModules             Json             @default("[]")
  consultationCtaEnabled       Boolean          @default(true)
  consultationCtaLabel         String?
  newsletterCtaEnabled         Boolean          @default(false)
  newsletterCtaLabel           String?
  newsletterCtaDescription     String?
  newsletterCtaHref            String?
  nextStepCtaLabel             String?
  nextStepCtaHref              String?
  founderSignatureEnabled      Boolean          @default(false)
  founderSignatureText         String?
  relatedGuideIds              String[]         @default([])
  views                        Int              @default(0)
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt
  author                       User             @relation("PrimaryGuideAuthor", fields: [authorId], references: [id])
  analytics                    GuideAnalytics[]
}

model GuideAnalytics {
  id          String   @id @default(cuid())
  guideId     String
  event       String
  sourceRoute String?
  visitorHash String?
  meta        Json?
  createdAt   DateTime @default(now())
  guide       Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([guideId, event, createdAt])
  @@index([event, createdAt])
  @@index([visitorHash, createdAt])
}

model Brand {
  id             String             @id @default(cuid())
  name           String             @unique
  website        String?
  logoUrl        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
  legacyPartners AffiliatePartner[]
  programs       AffiliateProgram[]
  posts          Post[]             @relation("PostAffiliateBrands")
}

model AffiliateProgram {
  id                String             @id @default(cuid())
  brandId           String
  network           AffiliateNetwork
  campaignId        String?            @unique
  commission        String?
  cookieLength      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  averageOrderValue Float?
  commissionRate    Float?
  links             AffiliateLink[]
  legacyPartners    AffiliatePartner[]
  brand             Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, network])
  @@index([brandId])
}

model AffiliatePartner {
  id              String              @id @default(uuid())
  name            String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  network         AffiliateNetwork
  advertiserId    String?
  commissionType  CommissionType
  commissionRate  String
  category        String?
  threeMonthEpc   Float?
  sevenDayEpc     Float?
  notes           String?
  isActive        Boolean             @default(true)
  allowedDomains  String[]            @default([])
  slug            String              @unique
  logoUrl         String?
  website         String?
  affiliateLink   String?
  brandId         String?
  programId       String?
  partnerType     String              @default("retailer")
  affiliatePid    String?
  baseUrl         String              @default("")
  affiliateTier   String              @default("T3")
  paymentRisk     Boolean             @default(false)
  retailerFallback String[]           @default([])
  routingPriority Int                 @default(99)
  allowedContexts Json                @default("[\"blog\"]")
  affiliateLinks  AffiliateLink[]
  brand           Brand?              @relation(fields: [brandId], references: [id])
  program         AffiliateProgram?   @relation(fields: [programId], references: [id])
  blogPosts       BlogPostAffiliate[]

  @@unique([name, network])
  @@index([brandId])
  @@index([programId])
}

model BlogPostAffiliate {
  id          String           @id @default(cuid())
  blogPostId  String
  affiliateId String
  createdAt   DateTime         @default(now())
  affiliate   AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  blogPost    Post             @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, affiliateId])
}

model AffiliateLink {
  id             String            @id @default(uuid())
  partnerId      String?
  destinationUrl String?
  code           String?           @unique
  label          String?
  blogPostId     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  programId      String?
  name           String?
  url            String?
  clicks         AffiliateClick[]
  blogPost       Post?             @relation(fields: [blogPostId], references: [id])
  partner        AffiliatePartner? @relation(fields: [partnerId], references: [id])
  program        AffiliateProgram? @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([partnerId])
  @@index([createdAt])
  @@index([blogPostId])
}

model AffiliateClick {
  id        String        @id @default(uuid())
  linkId    String
  ipHash    String?
  userAgent String?
  referrer  String?
  createdAt DateTime      @default(now())
  path      String?
  postId    String?
  link      AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  post      Post?         @relation(fields: [postId], references: [id])

  @@index([linkId, createdAt])
  @@index([postId], map: "idx_affiliateclick_postid")
  @@index([createdAt])
}

model BookingEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  type        String
  sourcePage  String?
  service     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  userAgent   String?
  ipHash      String?

  @@index([createdAt])
  @@index([type, createdAt])
}

model ConsultationRequest {
  id         Int                   @id @default(autoincrement())
  name       String
  email      String
  dueDate    DateTime?             @db.Timestamp(6)
  city       String?
  babyNumber String?
  message    String?
  intakeSummary Json?
  status     String?               @default("new")
  createdAt  DateTime?             @default(now()) @db.Timestamp(6)
  response   ConsultationResponse?
}

model ConsultationResponse {
  id             Int                 @id @default(autoincrement())
  consultationId Int                 @unique
  adminMessage   String
  meetingLink    String?
  scheduledTime  DateTime?           @db.Timestamp(6)
  createdAt      DateTime?           @default(now()) @db.Timestamp(6)
  consultation   ConsultationRequest @relation(fields: [consultationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ContactInquiry {
  id             Int       @id @default(autoincrement())
  fullName       String
  email          String
  service        String?
  dueDate        DateTime? @db.Timestamp(6)
  registryLink   String?
  homeType       String?
  budgetRange    String?
  topConcerns    String?
  biggestStress  String?
  location       String?
  levelOfSupport String?
  timeline       String?
  notes          String?
  referrer       String?
  sourceUrl      String?
  status         String?   @default("new")
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
}

model Stroller {
  id              String          @id @default(cuid())
  brand           String
  model           String
  displayName     String?
  summary         String?
  // Admin-entered Amazon affiliate link (manual override, not from any feed).
  amazonUrl       String?
  // ── Babylist (Impact.com) sync fields ──
  babylistSku       String?
  babylistUrl       String?
  babylistPrice     Float?
  babylistImage     String?
  babylistUpdatedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  compatibilities Compatibility[]
  spec            StrollerSpec?

  @@unique([brand, model], name: "brand_model")
  @@index([brand])
}

model StrollerSpec {
  id                  String    @id @default(cuid())
  strollerId          String    @unique
  stroller            Stroller  @relation(fields: [strollerId], references: [id], onDelete: Cascade)
  // ── Babylist (Impact.com) API data ──
  babylistSku         String?
  babylistUrl         String?
  babylistPrice       Float?
  babylistImage       String?
  babylistUpdatedAt   DateTime?
  // ── Quiz filter dimensions (manually curated, nullable until filled) ──
  priceRange          String?   // "budget" | "mid" | "premium" | "luxury"
  lifestyle           String[]  @default([]) // ["city","suburban","trail","travel"]
  foldType            String?   // "one-hand" | "compact" | "standard"
  isExpandable        Boolean   @default(false)
  maxWeightLbs        Int?
  ownWeightLbs        Float?
  suitableFromBirth   Boolean   @default(true)
  suitableForJogging  Boolean   @default(false)
  budgetMin           Int?
  budgetMax           Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model CarSeat {
  id              String                  @id @default(cuid())
  brand           String
  model           String
  displayName     String?
  seatType        CarSeatType            @default(INFANT)
  summary         String?
  // Admin-entered Amazon affiliate link (manual override, not from any feed).
  amazonUrl       String?
  // ── Babylist (Impact.com) sync fields ──
  babylistSku       String?
  babylistUrl       String?
  babylistPrice     Float?
  babylistImage     String?
  babylistUpdatedAt DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  compatibilities Compatibility[]

  @@unique([brand, model], name: "brand_model")
  @@index([brand])
  @@index([seatType])
}

model Compatibility {
  id                String                   @id @default(cuid())
  strollerId        String
  carSeatId         String
  compatibilityType CompatibilityType
  adapterRequired   Boolean                  @default(false)
  adapterType       String?
  notes             String?
  confidence        CompatibilityConfidence  @default(HIGH)
  // ── Babylist (Impact.com) adapter sync fields ──
  adapterBabylistUrl String?
  adapterPrice       Float?
  adapterImage       String?
  adapterBabylistSku String?
  adapterUpdatedAt   DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  stroller          Stroller                 @relation(fields: [strollerId], references: [id], onDelete: Cascade)
  carSeat           CarSeat                  @relation(fields: [carSeatId], references: [id], onDelete: Cascade)

  @@unique([strollerId, carSeatId])
  @@index([strollerId])
  @@index([carSeatId])
  @@index([compatibilityType])
}

// ─── Academy / Learn models ───────────────────────────────────────────────────

// Academy waitlist — email addresses collected before the full Academy opens.
// status: "pending" (default) | "approved" | "rejected"
model WaitlistEntry {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  dueDate   DateTime?
  source    String    @default("academy-waitlist")
  status    String    @default("pending")
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([status])
}

// A learner account is separate from the admin User model.
// Created on signup via the /learn enrollment flow.
// subscriptionTier: "free" | "academy" | "academy_plus" | "concierge"
model Learner {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  partnerName      String?
  dueDate          DateTime?
  babyNumber       Int?
  subscriptionTier String            @default("free")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workbookSessions WorkbookSession[]
  lessonProgress   LessonProgress[]

  @@index([email])
  @@index([subscriptionTier])
}

// Tracks when a member has visited an Academy module page.
// One row per learner × path × module — upserted on each visit.
model LessonProgress {
  id         String   @id @default(cuid())
  learnerId  String
  pathSlug   String   // "registry" | "nursery" | "gear" | "postpartum"
  moduleSlug String
  visitCount Int      @default(1)
  startedAt  DateTime @default(now())
  lastSeenAt DateTime @default(now()) @updatedAt
  learner    Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([learnerId, pathSlug, moduleSlug])
  @@index([learnerId])
  @@index([pathSlug])
  @@index([lastSeenAt])
}

// One WorkbookSession per learner per Academy path.
// e.g. learnerId=abc, pathSlug="registry"
model WorkbookSession {
  id          String             @id @default(cuid())
  learnerId   String?            // null = anonymous / guest session
  guestToken  String?            // stable browser token for unauthenticated saves
  pathSlug    String             // "registry" | "nursery" | "gear" | "postpartum"
  moduleSlug  String             // e.g. "what-to-register-first"
  startedAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  responses   WorkbookResponse[]
  learner     Learner?           @relation(fields: [learnerId], references: [id], onDelete: SetNull)

  @@unique([learnerId, pathSlug, moduleSlug])
  @@unique([guestToken, pathSlug, moduleSlug])
  @@index([learnerId])
  @@index([guestToken])
  @@index([pathSlug])
}

// One row per workbook prompt answer.
// promptId maps to a static prompt definition in the lesson TypeScript.
model WorkbookResponse {
  id        String          @id @default(cuid())
  sessionId String
  promptId  String          // e.g. "what-to-register-first-prompt-0"
  response  String
  savedAt   DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   WorkbookSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, promptId])
  @@index([sessionId])
}

// ─── Member registry links ────────────────────────────────────────────────────
// Members submit their registry URLs so Taylor can review them before
// a consultation. One User can have multiple Registry records (one per platform).

model Registry {
  id             String   @id @default(cuid())
  userId         String
  platform       Platform
  name           String?
  url            String
  itemCount      Int?
  completedCount Int?
  notes          String?
  isPublic       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Platform {
  BABYLIST
  AMAZON
  TARGET
  BUYBUYBABY
  WALMART
  OTHER
}

enum Role {
  USER
  ADMIN
  REVIEWER
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum BlogStage {
  IDEA
  OUTLINE
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum AffiliateNetwork {
  CJ
  IMPACT
  AWIN
  DIRECT
}

enum CommissionType {
  PERCENTAGE
  CPL
  FLAT_FEE
  VARIABLE
}

enum CarSeatType {
  INFANT
  CONVERTIBLE
  ALL_IN_ONE
}

enum CompatibilityType {
  DIRECT
  ADAPTER
  LIMITED
  LOCKED
  INCOMPATIBLE
}

enum CompatibilityConfidence {
  HIGH
  MEDIUM
  LOW
}

// ─── Dashboard workbook notes ─────────────────────────────────────────────────
// One note per user × path × module. Replaces the session-based WorkbookResponse
// chain for member dashboard saves (free-text, per-module notes).

model ModuleNote {
  id         String   @id @default(cuid())
  userId     String
  pathSlug   String
  moduleSlug String
  content    String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathSlug, moduleSlug])
  @@index([userId])
  @@index([pathSlug])
}

// ─── Babylist catalog mirror ──────────────────────────────────────────────────
// Local copy of the Babylist (Impact) catalog, refreshed by
// scripts/cacheBabylistCatalog.ts. Powers fast admin SKU search, since Impact's
// ItemSearch endpoint can't be used for keyword queries.
model BabylistCatalogItem {
  sku          String   @id // Impact CatalogItemId
  name         String
  manufacturer String?
  url          String
  imageUrl     String?
  price        Float?
  updatedAt    DateTime @updatedAt

  @@index([manufacturer])
}

// ─── Affiliate catalog (full store) ──────────────────────────────────────────
// Rich mirror of the entire affiliate catalog (Babylist via Impact, catalog
// 8981) — the foundation for product tools, registry guidance, product cards,
// and compatibility logic. Raw feed data lives here; TMBC editorial/enrichment
// lives in ProductEnrichment so a sync NEVER overwrites Taylor's manual work.
// Built alongside BabylistCatalogItem (the thin stroller cache), which stays.
model AffiliateCatalogProduct {
  id              String    @id @default(cuid())
  provider        String    @default("babylist_impact")
  catalogId       String    @default("8981")
  externalId      String    // feed `id` (Impact item id / prodsku)
  sku             String?
  gtin            String?
  brand           String?
  title           String
  description     String?
  rawCategory     String?   // feed google_product_category (unreliable — not used to categorize)
  productTypePath String?   // feed `product_type` — Babylist's own path; the categorization signal
  price           Float?
  salePrice       Float?
  currency        String    @default("USD")
  imageUrl        String?
  productUrl      String?   // decoded landing URL (babylist.com product page), if extracted
  affiliateUrl    String?   // feed `link` — pre-tracked affiliate URL, stored EXACTLY as provided
  manualAmazonUrl String?   // admin-entered Amazon affiliate override (human-owned; sync never touches)
  availability    String?
  inStock         Boolean   @default(true)
  itemGroupId     String?
  color           String?
  material        String?
  size            String?
  gender          String?
  ageGroup        String?
  retailer        String    @default("Babylist")
  rawPayload      Json?
  feedHash        String?
  firstSeenAt     DateTime  @default(now())
  lastSyncedAt    DateTime  @default(now())
  lastChangedAt   DateTime?
  isActiveInFeed  Boolean   @default(true)

  enrichment      ProductEnrichment?

  @@unique([provider, externalId])
  @@index([brand])
  @@index([title])
  @@index([sku])
  @@index([productTypePath])
  @@index([isActiveInFeed])
  @@index([lastSyncedAt])
}

// TMBC editorial / enrichment layer. A sync may CREATE these and set
// auto-categorized values, but once reviewStatus is REVIEWED (or a human edits),
// the sync must NOT overwrite the TMBC-controlled fields below.
model ProductEnrichment {
  id                String   @id @default(cuid())
  rawProductId      String   @unique
  rawProduct        AffiliateCatalogProduct @relation(fields: [rawProductId], references: [id], onDelete: Cascade)

  canonicalBrand    String?
  canonicalName     String?
  slug              String?  @unique

  // Taxonomy (strings; canonical lists live in lib/catalog/taxonomy.ts)
  tmbcCategory      String?
  tmbcSubcategory   String?
  productType       String?
  parentJourney     String?
  registryPriority  String?
  lifecycleStage    String?

  // Visibility + recommendation status
  visibility        String   @default("auto")
  isPublic          Boolean  @default(false)
  isFeatured        Boolean  @default(false)
  isTaylorPick      Boolean  @default(false)
  isRecommended     Boolean  @default(false)
  isWorthKnowing    Boolean  @default(false)
  isSkipForMost     Boolean  @default(false)

  // Review workflow
  needsReview       Boolean  @default(true)
  reviewStatus      CatalogReviewStatus @default(AUTO_CATEGORIZED)
  confidenceScore   Float?

  // Editorial
  editorialSummary  String?
  taylorsNote       String?
  internalNotes     String?
  tags              String[] @default([])
  useCaseTags       String[] @default([])
  lifestyleTags     String[] @default([])
  compatibilityTags String[] @default([])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  reviewedAt        DateTime?
  reviewedBy        String?

  @@index([tmbcCategory])
  @@index([productType])
  @@index([parentJourney])
  @@index([reviewStatus])
  @@index([needsReview])
  @@index([isTaylorPick])
  @@index([isPublic])
}

enum CatalogReviewStatus {
  AUTO_CATEGORIZED
  NEEDS_REVIEW
  REVIEWED
  HIDDEN
}
